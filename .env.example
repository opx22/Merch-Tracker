# ==========================================
# Merch Tracker — Supabase Environment Variables
# ==========================================
# Fill in your project credentials from the Supabase Dashboard:
# Dashboard -> Project Settings -> API

# 1. Project URL (e.g., https://your-project-ref.supabase.co)
VITE_SUPABASE_URL=your_supabase_project_url_here

# 2. Project Anon / Public API Key (starts with eyJ...)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
